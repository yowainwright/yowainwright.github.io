module.exports = {"data":{"site":{"siteMetadata":{"title":"Jeffry.in","author":"Jeff Wainwright"}},"markdownRemark":{"id":"/Users/jwainwright/Dropbox/me/git-docs/yowainwright.github.io/src/pages/2017-03-27-week-10-17.md absPath of file >>> MarkdownRemark","html":"<p>I’m getting to this post a bit late—1 week. Why? I switched teams at work. I’m now be working on an analytics product. </p>\n<h2>Working on Analytics</h2>\n<p>I’m very happy to working on building an analytics tool for my company. The tool will take in information as a customer navigates our sites and turn that information into a uniform data object that can be used by various analytics platforms like Adobe, Looker or Google Analytics. </p>","frontmatter":{"featured_image":null,"meta":"Week 10, 2017—This was a week with few words as I was transitioning teams at work, sick and injured.","title":"Week 10, A Week With Few Words","date":"March 27, 2017"}}},"pathContext":{"path":"/week-10-17/"}}


