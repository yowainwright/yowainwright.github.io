{
  "name": "Jeffry.in",
  "version": "2.13.0",
  "private": true,
  "description": "Jeffry.in, Jeff Wainwright's blog",
  "homepage": "https://github.com/yowainwright/yowainwright.github.io#readme",
  "bugs": {
    "url": "https://github.com/yowainwright/yowainwright.github.io/issues"
  },
  "license": "MIT",
  "author": "Jeff Wainwright <yowainwright@gmail.com> (jeffry.in)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yowainwright/yowainwright.github.io"
  },
  "type": "module",
  "main": "README.md",
  "scripts": {
    "prebuild": "playwright install chromium --with-deps",
    "build": "bun run update-pricing && bun run build:css && bun run build:search && next build && bun run build:rss",
    "update-pricing": "bun scripts/update-ai-pricing/index.ts",
    "build:search": "bun scripts/generate-search-data.ts",
    "build:local": "bun run build:css && next build && bun run build:rss",
    "build:rss": "bun scripts/rss/index.ts",
    "build:css": "bun scripts/generate-component-styles.ts && sass --style=compressed lib/client/styles/scss/main.scss public/assets/jeffry.in.css",
    "dev": "mprocs",
    "dev:next": "next dev --port 34729",
    "format": "oxfmt --write \"**/*.{js,jsx,ts,tsx}\" \"!node_modules/**\" \"!public/**\" \"!out/**\" \"!tmp/**\" \"!content/**\" --threads=1",
    "format:check": "oxfmt --check \"**/*.{js,jsx,ts,tsx}\" \"!node_modules/**\" \"!public/**\" \"!out/**\" \"!tmp/**\" \"!content/**\" --threads=1",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint -c .oxlintrc.json . --fix",
    "test": "bun test",
    "prepare": "bun scripts/install-hooks.ts && bun run update && bun run maintain",
    "start": "next start",
    "update": "bun run update:packages && bun run update:actions",
    "update:packages": "codependence --config package.json --update",
    "update:actions": "codependence --config .codependencerc --update",
    "maintain": "pastoralist"
  },
  "dependencies": {
    "@atproto/api": "0.18.9",
    "@automattic/social-previews": "3.0.0",
    "@giscus/react": "3.1.0",
    "@keystatic/core": "0.5.48",
    "@keystatic/next": "5.0.4",
    "@mdx-js/loader": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@next/mdx": "16.2.10",
    "@next/third-parties": "16.2.10",
    "@sentry/nextjs": "10.67.0",
    "@tanstack/react-table": "8.21.3",
    "effect": "3.21.2",
    "firebase": "12.16.0",
    "fuse.js": "7.1.0",
    "lucide-react": "0.542.0",
    "next": "16.2.10",
    "next-mdx-remote": "5.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-zoom-pan-pinch": "3.7.0",
    "recharts": "3.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@shikijs/colorized-brackets": "1.29.2",
    "@shikijs/rehype": "1.29.2",
    "@shikijs/transformers": "1.29.2",
    "@types/bun": "latest",
    "@types/jsdom": "27.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vercel/og": "0.8.6",
    "codependence": "1.0.2",
    "gray-matter": "4.0.3",
    "jsdom": "28.0.0",
    "oxfmt": "0.50.0",
    "oxlint": "1.67.0",
    "pastoralist": "1.12.8",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "playwright": "1.57.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-mermaidjs": "7.0.0",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "rxjs": "7.8.2",
    "sanitize-filename": "1.6.4",
    "sass": "1.101.3",
    "unified": "11.0.5"
  },
  "peerDependencies": {
    "typescript": "5.8.3"
  },
  "overrides": {
    "@grpc/grpc-js": "1.9.16",
    "next-mdx-remote": "6.0.0",
    "protobufjs": "7.6.4",
    "undici": "7.28.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.9",
  "codependence": {
    "mode": "verbose",
    "codependencies": [
      "@next/mdx",
