module.exports = {"data":{"site":{"siteMetadata":{"title":"Jeffry.in","author":"Jeff Wainwright"}},"markdownRemark":{"id":"/Users/jwainwright/Dropbox/me/git-docs/yowainwright.github.io/src/pages/about.md absPath of file >>> MarkdownRemark","html":"<p>I’m software engineer at <a href=\"https://www.dollarshaveclub.com/\">Dollar Shave Club</a>. I started writing software because I’m passionate about making things and contributing. Unrelated to software, I enjoy <a href=\"https://www.strava.com/athletes/722335\">riding bikes</a>, <a href=\"https://www.strava.com/athletes/722335\">running</a>, and surfing.</p>\n<br>\n<hr>\n<h2>Open Source</h2>\n<ul>\n<li><strong><a href=\"https://github.com/dollarshaveclub/stickybits\">StickyBits</a>:</strong> Stickybits is a lightweight (&#x3C;2KB) alternative to position: sticky polyfills</li>\n<li><strong><a href=\"https://github.com/dollarshaveclub/scrolldir\">Scrolldir</a>:</strong> y-axis scroll direction without jitter</li>\n<li><strong><a href=\"https://github.com/dollarshaveclub/shave\">Shave</a>:</strong> a minimal JavaScript Plugin for Truncated text</li>\n<li><strong><a href=\"https://github.com/dollarshaveclub/reframe.js\">Reframe.js</a>:</strong> a minimal JavaScript Plugin for reframing html elements so they’re an intrisic ratio of the original—greate for embeds</li>\n</ul>\n<h2>Publications</h2>\n<ul>\n<li><strong><a href=\"https://css-tricks.com/stickybits-alternative-position-sticky-polyfills/\">Stickybits: an alternative to position: sticky polyfills</a></strong> - CSS Tricks</li>\n</ul>\n<br>\n<hr>\n<br>\n<p align=\"center\">Email me at <a href=\"mailto:yowainwright@gmail.com\">yowainwright@gmail.com</a> or reach out on socially.</p>\n<p align=\"center\">\n  <a href=\"https://github.com/yowainwright\"><strong>Github</strong></a>&nbsp;&nbsp;\n  <a href=\"https://instagram.com/yowainwright\"><strong>Instagram</strong></a>&nbsp;&nbsp;\n  <a href=\"https://twitter.com/yowainwright\"><strong>Twitter</strong></a>&nbsp;&nbsp;\n  <a href=\"https://ratherbe.in\"><strong>Tumblr</strong></a>&nbsp;&nbsp;\n  <a href=\"https://www.strava.com/athletes/722335\"><strong>Strava</strong></a>&nbsp;&nbsp;\n  <a href=\"https://www.linkedin.com/in/jeffrywainwright/\"><strong>LinkedIn</strong></a>&nbsp;&nbsp;\n</p>\n<br>","frontmatter":{"featured_image":null,"meta":"About Jeff Wainwright","title":"About me, Jeff Wainwright","date":"July 28, 2017","path":"/about/"}}},"pathContext":{"path":"/about/"}}


